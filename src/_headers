# 🚀 HTML FILES - NO CACHE (always fetch fresh from server)
# This prevents Cloudflare from serving stale HTML after deployments
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# 🔒 GLOBAL SECURITY HEADERS - 100/100 Score
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://accounts.google.com https://cdn.jsdelivr.net https://unpkg.com https://sdk.amazonaws.com https://www.googletagmanager.com https://www.google-analytics.com https://analytics.google.com https://ssl.google-analytics.com https://static.cloudflareinsights.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https: blob:; media-src 'self' https://everyayah.com https://quranicaudio.com https://server8.mp3quran.net; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://accounts.google.com https://www.googleapis.com https://oauth2.googleapis.com https://lh3.googleusercontent.com https://www.google-analytics.com https://analytics.google.com https://stats.g.doubleclick.net https://static.cloudflareinsights.com https://cloudflareinsights.com https://images.unsplash.com https://cdn.jsdelivr.net https://unpkg.com https://sdk.amazonaws.com https://challenges.cloudflare.com https://quranicaudio.com https://server8.mp3quran.net https://everyayah.com https://get.geojs.io https://ipapi.co https://freegeoip.app; frame-src 'self' https://accounts.google.com https://www.instagram.com https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests;

# Sitemap - MUST be indexable by Google
/sitemap.xml
  X-Robots-Tag: all
  Content-Type: application/xml
  Cache-Control: public, max-age=3600

# Allow social media bots to access images for link previews
/assets/images/*
  Access-Control-Allow-Origin: *
  X-Robots-Tag: all
  Cache-Control: public, max-age=31536000

# Specific rule for social card images - must be accessible to all bots
/assets/images/social-card.png
  Access-Control-Allow-Origin: *
  X-Robots-Tag: all
  Cache-Control: public, max-age=31536000

/assets/images/social-card.jpg
  Access-Control-Allow-Origin: *
  X-Robots-Tag: all
  Cache-Control: public, max-age=31536000

/assets/images/quran-social-card.png
  Access-Control-Allow-Origin: *
  X-Robots-Tag: all
  Cache-Control: public, max-age=31536000

/assets/images/quran-social-card.jpg
  Access-Control-Allow-Origin: *
  X-Robots-Tag: all
  Cache-Control: public, max-age=31536000
