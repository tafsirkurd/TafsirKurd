# 🎬 Admin page - FFmpeg MOV conversion requires these headers
/admin-islamvoice-management.html
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  Cache-Control: no-cache, no-store, must-revalidate

# 🚀 HTML FILES + DIRECTORY INDEXES - NO CACHE (always fetch fresh from server)
# This prevents Cloudflare from serving stale HTML after deployments
# NOTE: directory index files (e.g. /app/ → app/index.html) are served without .html in URL,
# so they need explicit path rules in addition to the *.html glob rules.
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/**/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/app/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/app
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# 🔄 Service worker — must never be cached (browser checks for SW updates on every navigate)
/service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# 🕌 Prayer data — static annual JSON, 1h CDN cache so corrections propagate within 1h
/prayer-data/*
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *

# 📦 JS & CSS - Long cache, immutable (all served with ?v= cache-bust param)
# Note: /*.js only matches root-level files — /**/*.js covers all subdirectories
/*.js
  Cache-Control: public, max-age=31536000, immutable

/**/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/**/*.css
  Cache-Control: public, max-age=31536000, immutable

# 🔤 Fonts — immutable (versioned via ?v= param in HTML)
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# 🎨 FontAwesome — immutable (versioned via ?v= param in HTML)
/assets/fontawesome/*
  Cache-Control: public, max-age=31536000, immutable

# 🎬 Videos — long cache (content-addressed by filename)
/assets/videos/*
  Cache-Control: public, max-age=31536000, immutable

