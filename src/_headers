# Allow social media bots to access images for link previews
/assets/images/*
  Access-Control-Allow-Origin: *
  X-Robots-Tag: all
  Cache-Control: public, max-age=31536000

# Specific rule for social card images - must be accessible to all bots
/assets/images/social-card.png
  Access-Control-Allow-Origin: *
  X-Robots-Tag: all
  Cache-Control: public, max-age=31536000

/assets/images/social-card.jpg
  Access-Control-Allow-Origin: *
  X-Robots-Tag: all
  Cache-Control: public, max-age=31536000

/assets/images/quran-social-card.png
  Access-Control-Allow-Origin: *
  X-Robots-Tag: all
  Cache-Control: public, max-age=31536000

/assets/images/quran-social-card.jpg
