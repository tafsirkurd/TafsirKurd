# Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git!

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Admin Credentials (Fallback Authentication)
ADMIN_EMAIL=admin@tafsirkurd.com
ADMIN_PASSWORD=YourStrongPasswordHere123!

# Node Environment
NODE_ENV=development

# Security Notes:
# 1. Keep your .env file in .gitignore
# 2. Use strong passwords (min 12 characters, mixed case, numbers, symbols)
# 3. Rotate credentials regularly
# 4. Never share your .env file
# 5. Use different credentials for development and production
