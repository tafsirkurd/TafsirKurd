require_relative '../../node_modules/@capacitor/ios/scripts/pods_helpers'

platform :ios, '15.0'
use_frameworks!

# workaround to avoid Xcode caching of Pods that requires
# temporary removal of target after subsequent `pod install`
def capacitor_pods
  pod 'Capacitor', :path => '../../node_modules/@capacitor/ios'
  pod 'CapacitorCordova', :path => '../../node_modules/@capacitor/ios'
end

target 'App' do
  capacitor_pods
  # Add your Pods here
end

# apple-sign-in Plugin.swift is patched via node --eval in codemagic.yaml
# The codemagic.yaml patch runs BEFORE cap sync, and the Diagnose step
# re-patches AFTER cap sync if needed. No post_install hook needed here.
