{
    "name": "tafsir-kurd",
    "version": "2.0.0",
    "description": "Modern, fast, and offline-capable Quran platform with Kurdish Tafsir - قورئانا پیرۆز ب تەفسیرا کوردی",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "dev": "npx serve src",
        "build": "node scripts/bump-sw-version.js",
        "build:prod": "node scripts/bump-sw-version.js production-deploy",
        "deploy": "npx wrangler pages deploy src --project-name tafsirkurd",
        "deploy:check": "npm test && npm run deploy",
        "test": "node scripts/smoke-test.js",
        "check-translations": "node scripts/check-translations.cjs",
        "lint": "node scripts/lint-check.js",
        "format": "echo 'Formatting code...'",
        "cap:sync": "npx cap sync && node scripts/verify-assets.js",
        "cap:ios:sync": "npx cap sync ios && node scripts/strip-ios-fonts.js && node scripts/verify-assets.js",
        "cap:ios": "npx cap open ios",
        "cap:android": "npx cap open android",
        "android:live": "node scripts/android-live.js",
        "preflight": "node scripts/preflight.js",
        "check:versions": "node scripts/check-versions.js",
        "check:sw": "node scripts/check-sw.js",
        "test:scheduler": "node --test tests/notification-scheduler.test.mjs"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/tafsirkurd/tafsir-kurd.git"
    },
    "keywords": [
        "quran",
        "tafsir",
        "kurdish",
        "islamic",
        "pwa",
        "offline-first",
        "supabase"
    ],
    "author": "Tafsir Kurd Team",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/tafsirkurd/tafsir-kurd/issues"
    },
    "homepage": "https://tafsirkurd.com",
    "dependencies": {
        "@capacitor-community/media": "^9.0.2",
        "@capacitor/android": "8.0.1",
        "@capacitor/app": "8.0.1",
        "@capacitor/browser": "8.0.1",
        "@capacitor/cli": "8.0.1",
        "@capacitor/core": "8.0.1",
        "@capacitor/filesystem": "8.0.0",
        "@capacitor/haptics": "8.0.1",
        "@capacitor/ios": "8.0.1",
        "@capacitor/local-notifications": "8.0.1",
        "@capacitor/preferences": "8.0.1",
        "@capacitor/push-notifications": "8.0.1",
        "@supabase/supabase-js": "2.55.0",
        "@upstash/redis": "^1.35.8",
        "bcrypt-ts": "^8.0.0",
        "dompurify": "^3.3.1",
        "googleapis": "^140.0.0",
        "html-to-image": "^1.11.13",
        "isomorphic-dompurify": "^2.34.0",
        "jsonwebtoken": "^9.0.2",
        "sharp": "^0.34.5",
        "tweetnacl": "^1.0.3",
        "wawoff2": "^2.0.1"
    },
    "overrides": {
        "@capacitor/core": "8.0.1",
        "@capacitor/ios": "8.0.1",
        "@capacitor/android": "8.0.1",
        "@capacitor/cli": "8.0.1",
        "@capacitor/app": "8.0.1",
        "@capacitor/browser": "8.0.1",
        "@capacitor/filesystem": "8.0.0",
        "@capacitor/haptics": "8.0.1",
        "@capacitor/local-notifications": "8.0.1",
        "@capacitor/preferences": "8.0.1",
        "@capacitor/push-notifications": "8.0.1",
        "@capacitor/splash-screen": "0.0.0",
        "@capacitor/share": "0.0.0",
        "@capacitor/status-bar": "0.0.0",
        "@capacitor-community/keep-awake": "0.0.0",
        "@capacitor-community/speech-recognition": "0.0.0"
    },
    "engines": {
        "node": ">=16.0.0",
        "npm": ">=8.0.0"
    },
    "devDependencies": {
        "ffmpeg-static": "^5.3.0",
        "jsdom": "^28.1.0",
        "typescript": "^5.9.3"
    }
}
