{
  "redirects": [
    {
      "source": "/tv",
      "destination": "/islamvoice",
      "permanent": true
    },
    {
      "source": "/tv.html",
      "destination": "/islamvoice.html",
      "permanent": true
    },
    {
      "source": "/admin-tv-management.html",
      "destination": "/admin-islamvoice-management.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/src/admin-islamvoice-management.html",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        }
      ]
    }
  ]
}
