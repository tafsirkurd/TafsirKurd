<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0E100E"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp"
    android:gravity="center">

    <!-- Reference (top, accent color) -->
    <TextView
        android:id="@+id/referenceText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#23BD69"
        android:fontFamily="@font/ibm_plex_arabic"
        android:gravity="center"
        android:maxLines="1"
        android:layout_marginBottom="8dp" />

    <!-- Arabic text (Hafs font, centered) -->
    <TextView
        android:id="@+id/arabicText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/uthmanic_hafs"
        android:gravity="center"
        android:lineSpacingMultiplier="1.6"
        android:maxLines="5"
        android:ellipsize="end" />

    <!-- Separator line -->
    <View
        android:id="@+id/separator"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1FFFFFFF"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        android:visibility="gone" />

    <!-- Kurdish tafsir -->
    <TextView
        android:id="@+id/tafsirText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#80FFFFFF"
        android:fontFamily="@font/ibm_plex_arabic"
        android:gravity="end"
        android:lineSpacingMultiplier="1.5"
        android:maxLines="4"
        android:ellipsize="end"
        android:visibility="gone" />

</LinearLayout>
