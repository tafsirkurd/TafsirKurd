<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon foreground for API 24 vector path.
     The actual TafsirKurd logo is in the mipmap/ic_launcher_foreground.png files.
     The adaptive icon (mipmap-anydpi-v26/ic_launcher.xml) references
     @mipmap/ic_launcher_foreground (the PNG), NOT this drawable, so this file
     is only used if something explicitly references @drawable/ic_launcher_foreground.
     Replaced from stock Android robot vector to a transparent placeholder. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Intentionally empty — transparent foreground.
         Use @mipmap/ic_launcher_foreground for the actual app icon. -->
</vector>
